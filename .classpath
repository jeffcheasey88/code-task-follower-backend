<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="src" path="src"/>
	<classpathentry exported="true" kind="lib" path="peer-at-code-framework-1.2.0.jar"/>
	<classpathentry exported="true" kind="lib" path="Treasure.jar"/>
	<classpathentry kind="lib" path="TreasureProcessor.jar"/>
	<classpathentry kind="src" path=".orm_generated">
		<attributes>
			<attribute name="optional" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="lib" path="mysql-connector-j-9.4.0.jar"/>
	<classpathentry kind="output" path="bin"/>
</classpath>
