eclipse.preferences.version=1
org.eclipse.jdt.apt.aptEnabled=true
org.eclipse.jdt.apt.genSrcDir=.orm_generated
org.eclipse.jdt.apt.genTestSrcDir=.orm_generated_tests
org.eclipse.jdt.apt.processorOptions/treasure.dependencies=postgresql-42.7.13.jar;peer-at-code-framework-1.2.0.jar;Treasure.jar
org.eclipse.jdt.apt.processorOptions/treasure.java.args.jvm=-parameters
org.eclipse.jdt.apt.processorOptions/treasure.java.home=C\:\\Program Files\\Java\\jdk-25
org.eclipse.jdt.apt.processorOptions/treasure.java.version=25
org.eclipse.jdt.apt.processorOptions/treasure.mysql.schema=true
org.eclipse.jdt.apt.processorOptions/treasure.providers=dev.peerat.mapping.providers.postgresql.PostgreSQLProvider
org.eclipse.jdt.apt.processorOptions/treasure.source=%sourcepath%
org.eclipse.jdt.apt.reconcileEnabled=true
